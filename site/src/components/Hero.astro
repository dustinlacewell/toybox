---
import ToyboxDemo from "../demo/ToyboxDemo";
import DownloadButtons from "./DownloadButtons.astro";
import pkg from "../../package.json";

const version = pkg.version;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-grid pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 pt-12 md:pt-16 text-center">
    <h1
      class="animate-fade-up delay-100 text-5xl md:text-7xl font-bold tracking-tight leading-[1.03] text-balance"
    >
      Your whole asset library.
      <br />
      <span class="bg-gradient-to-r from-accent-soft via-accent to-mint bg-clip-text text-transparent">
        Browse, preview, export.
      </span>
    </h1>

    <p
      class="animate-fade-up delay-200 mt-7 mx-auto max-w-2xl text-lg md:text-xl text-slate-300 text-pretty leading-relaxed"
    >
      Toybox is a native desktop app for your glTF game-asset library. Filter
      by pack and category, search instantly, spin any model in a real 3D
      viewer, then export a clean copy or a merged GLB.
    </p>

    <div class="animate-fade-up delay-300 mt-9">
      <DownloadButtons />
    </div>

    <div class="animate-fade-up delay-400 mt-12 relative text-left">
      <div class="absolute -inset-x-8 -inset-y-4 bg-gradient-to-b from-accent/20 via-transparent to-transparent blur-3xl opacity-50 pointer-events-none"></div>

      <div class="relative rounded-xl border border-hairline bg-slate-900 overflow-hidden shadow-glow">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-hairline bg-slate-850/80">
          <span class="h-3 w-3 rounded-full bg-slate-700"></span>
          <span class="h-3 w-3 rounded-full bg-slate-700"></span>
          <span class="h-3 w-3 rounded-full bg-slate-700"></span>
          <span class="ml-3 text-xs font-mono text-slate-400">Toybox — Asset Library</span>
          <span class="ml-auto text-[10px] font-mono text-slate-500">live demo · v{version}</span>
        </div>

        <div class="relative h-[520px] md:h-[640px] bg-slate-900">
          <ToyboxDemo client:only="react" />
        </div>
      </div>

      <p class="mt-3 text-center text-xs text-slate-500 italic">
        This is the real app — a slice of the Polygon Prototype pack. Click a
        card to open the 3D viewer, drag to orbit.
      </p>
    </div>
  </div>
</section>
