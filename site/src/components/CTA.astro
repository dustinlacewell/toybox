---
import DownloadButtons from "./DownloadButtons.astro";
---

<section class="relative pb-28">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <div class="rounded-2xl border border-hairline bg-slate-900/60 backdrop-blur px-8 py-14 shadow-glow">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-balance">
        Get Toybox
      </h2>
      <p class="mt-4 mx-auto max-w-md text-slate-300 leading-relaxed text-pretty">
        Free and open source. Point it at your glTF library and start browsing
        in seconds.
      </p>
      <div class="mt-8">
        <DownloadButtons />
      </div>
    </div>
  </div>
</section>
