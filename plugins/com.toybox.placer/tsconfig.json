{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "outDir": "dist"
    // `@ldlework/toybox-sdk` (+ `/ui`) and `react` are externals the app resolves
    // at runtime via its import map. Types come from the linked SDK package (its
    // generated dist/*.d.ts) — a real installed dependency, not a hand-mirror.
    // The emitted JS keeps the bare imports untouched (no bundling).
  },
  "include": ["index.ts", "ui/**/*.tsx"]
}
