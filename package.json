{
  "name": "toybox",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm plugins:build && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "sdk:build": "tsc -p packages/toybox-sdk/tsconfig.json && tsc -p packages/toybox-sdk/tsconfig.ui-types.json",
    "plugins:build": "pnpm sdk:build && tsc -p plugins/com.toybox.placer/tsconfig.json && tsc -p plugins/com.toybox.gltf-importer/tsconfig.json",
    "plugins:link": "node scripts/link-plugins.mjs",
    "plugins:dev": "pnpm plugins:build && pnpm plugins:link"
  },
  "dependencies": {
    "@ldlework/toybox-sdk": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-virtual": "^3.14.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.6.0",
    "cjs-module-lexer": "^2.2.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vite-import-maps": "^0.2.6"
  }
}
